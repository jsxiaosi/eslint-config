{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {},
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "packages/commitlint/tsconfig.json"],
  "exclude": ["./fixtures/**/*.*", "./_fixtures/**/*.*"]
}
