{
  "name": "@jsxiaosi/linting-configs",
  "type": "module",
  "version": "1.0.24",
  "private": true,
  "description": "eslint 配置",
  "publishConfig": {
    "access": "public"
  },
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/jsxiaosi/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsxiaosi/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/jsxiaosi/eslint-config/issues"
  },
  "keywords": [
    "eslint"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "release": "bump package.json packages/*/package.json",
    "release:eslint": "pnpm run -C packages/eslint release",
    "smoke": "node scripts/smoke-check.mjs",
    "smoke:eslint": "node scripts/smoke-check.mjs eslint",
    "smoke:prettier": "node scripts/smoke-check.mjs prettier",
    "smoke:commitlint": "node scripts/smoke-check.mjs commitlint",
    "lint:eslint": "eslint ./packages --fix ",
    "lint:test_eslint": "eslint ./fixtures",
    "lint:prettier": "prettier . --write",
    "prepare": "husky",
    "cz": "czg",
    "log": "conventional-changelog -p cmyr-config -i CHANGELOG.md -s -r 0",
    "build": "pnpm build:eslint && pnpm build:commitlint && pnpm build:prettier",
    "build:eslint": "pnpm run -C packages/eslint build",
    "build:prettier": "pnpm run -C packages/prettier build",
    "build:commitlint": "pnpm run -C packages/commitlint build",
    "typegen": "pnpm run -C packages/eslint typegen",
    "tag": "pnpm run release && pnpm log",
    "prepublishOnly": "pnpm run build",
    "postinstall": "pnpm run build"
  },
  "dependencies": {
    "@jsxiaosi/commitlint-config": "workspace:*",
    "@jsxiaosi/eslint-config": "workspace:*",
    "@jsxiaosi/eslint-config-prettier": "workspace:*",
    "globals": "catalog:"
  },
  "devDependencies": {
    "@jsdevtools/version-bump-prompt": "catalog:",
    "@types/node": "catalog:",
    "commitlint": "catalog:",
    "conventional-changelog-cli": "catalog:",
    "czg": "catalog:",
    "eslint": "catalog:",
    "glob": "catalog:",
    "husky": "catalog:",
    "prettier": "catalog:",
    "rolldown": "catalog:",
    "rolldown-plugin-dts": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "resolutions": {
    "typescript": "^6.0.2"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
